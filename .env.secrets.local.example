# Copy this file to `.env.secrets.local` and fill in real values.
# Then run:
#   npm run secrets:sync -- --repo owner/name
#
# Supported formats:
#   KEY=value
#   KEY="quoted value"
#   KEY<<EOF
#   multiline value
#   EOF

GHCR_READ_USER=
GHCR_READ_TOKEN=

# Local dev notes:
# - Use `127.0.0.1:5433` when you forward the DB port to your machine.
# - If the API runs in Docker and the tunnel runs on your Windows host, `host.docker.internal:5433` may be the correct host.
# - Add `GSS Encryption Mode=Disable` to local PostgreSQL connection strings if you see the `libgssapi_krb5.so.2` warning.
# - For local RabbitMQ TLS, run `powershell -File scripts/tools/ensure-rabbitmq-local-tls.ps1` and then `docker compose up -d --build`.
# - This file can be loaded by `docker compose` or your shell before `dotnet run`.
# - `launchSettings.json` is intentionally kept free of secrets.

ConnectionStrings__IdentityConnection=
ConnectionStrings__AccountsConnection=
ConnectionStrings__CommunityConnection=
ConnectionStrings__DiscoveryConnection=
ConnectionStrings__NotificationConnection=

Messaging__RabbitMq__Uri=amqps://RABBITMQ_USER:RABBITMQ_PASSWORD@norge360-rabbitmq:5671/
Infrastructure__DistributedCache__RedisConnectionString=
Infrastructure__DataProtection__RedisConnectionString=

Discovery__InternalEvents__Token=
Security__TrustedGateway__Keys__0__Secret=
Security__TrustedGateway__Keys__1__Secret=
TURNSTILE_SECRET=

Meilisearch__ApiKey=
MEILI_MASTER_KEY=
AUTH_JWT_SIGNING_PRIVATE_KEY_PEM<<EOF
-----BEGIN PRIVATE KEY-----
<set-in-cluster>
-----END PRIVATE KEY-----
EOF

InvitationDelivery__SmtpUserName=
InvitationDelivery__SmtpPassword=
Notification__RabbitMq__Username=
Notification__RabbitMq__Password=
Notification__Email__Smtp__UserName=
Notification__Email__Smtp__Password=

Media__CloudflareR2__AccountId=
Media__CloudflareR2__AccessKeyId=
Media__CloudflareR2__SecretAccessKey=

# Optional example for a multiline secret:
# AUTH_JWT_SIGNING_PRIVATE_KEY_PEM<<EOF
# -----BEGIN PRIVATE KEY-----
# ...
# -----END PRIVATE KEY-----
# EOF
