# Copy this file to `.env.secrets.local` and fill in real values.
# Then run:
#   npm run secrets:sync -- --repo owner/name
#
# Supported formats:
#   KEY=value
#   KEY="quoted value"
#   KEY<<EOF
#   multiline value
#   EOF

GHCR_READ_USER=
GHCR_READ_TOKEN=

ConnectionStrings__IdentityConnection=
ConnectionStrings__AccountsConnection=
ConnectionStrings__CommunityConnection=
ConnectionStrings__DiscoveryConnection=
ConnectionStrings__NotificationConnection=

Messaging__RabbitMq__Uri=
Infrastructure__DistributedCache__RedisConnectionString=
Infrastructure__DataProtection__RedisConnectionString=

Discovery__InternalEvents__Token=
Security__TrustedGateway__Keys__0__Secret=
Security__TrustedGateway__Keys__1__Secret=
TURNSTILE_SECRET=

Meilisearch__ApiKey=
MEILI_MASTER_KEY=
AUTH_JWT_SIGNING_PRIVATE_KEY_PEM<<EOF
-----BEGIN PRIVATE KEY-----
<set-in-cluster>
-----END PRIVATE KEY-----
EOF

InvitationDelivery__SmtpUserName=
InvitationDelivery__SmtpPassword=
Notification__RabbitMq__Username=
Notification__RabbitMq__Password=
Notification__Email__Smtp__UserName=
Notification__Email__Smtp__Password=

Media__CloudflareR2__AccountId=
Media__CloudflareR2__AccessKeyId=
Media__CloudflareR2__SecretAccessKey=

# Optional example for a multiline secret:
# AUTH_JWT_SIGNING_PRIVATE_KEY_PEM<<EOF
# -----BEGIN PRIVATE KEY-----
# ...
# -----END PRIVATE KEY-----
# EOF
