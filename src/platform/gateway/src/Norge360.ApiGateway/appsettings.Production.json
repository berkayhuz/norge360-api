{
  "AllowedHosts": "norge360.com",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080"
      },
      "Https": {
        "Url": "https://+:8443"
      }
    }
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Security": {
    "Cors": {
      "AllowedOrigins": [
        "https://norge360.com",
        "https://auth.norge360.com"
      ],
      "AllowCredentials": true
    },
    "ForwardedHeaders": {
      "ForwardLimit": 2,
      "KnownProxies": [],
      "KnownNetworks": ["10.0.0.0/8"]
    },
    "TrustedGateway": {
      "RequireTrustedGateway": true,
      "Source": "Norge360.ApiGateway",
      "AllowedSources": ["Norge360.ApiGateway"],
      "CurrentKeyId": "gateway-prod-key-2026-01",
      "Keys": [
        {
          "KeyId": "gateway-prod-key-2026-01",
          "Secret": "",
          "Enabled": true,
          "SignRequests": true
        }
      ]
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-api-route": {
        "ClusterId": "auth-api-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Metadata": {
          "TrustedGatewaySigning": "true"
        }
      },
      "accounts-api-route": {
        "ClusterId": "accounts-api-cluster",
        "Match": {
          "Path": "/api/accounts/{**catch-all}"
        },
        "Metadata": {
          "TrustedGatewaySigning": "true"
        }
      },
      "search-api-route": {
        "ClusterId": "search-api-cluster",
        "Match": {
          "Path": "/api/v1/search/{**catch-all}"
        },
        "Metadata": {
          "TrustedGatewaySigning": "true"
        }
      },
      "auth-jwks-route": {
        "ClusterId": "auth-api-cluster",
        "Match": {
          "Path": "/.well-known/jwks.json"
        }
      },
      "auth-openid-configuration-route": {
        "ClusterId": "auth-api-cluster",
        "Match": {
          "Path": "/.well-known/openid-configuration"
        }
      }
    },
    "Clusters": {
      "auth-api-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:00:15",
          "Version": "2",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 256,
          "EnableMultipleHttp2Connections": true,
          "DangerousAcceptAnyServerCertificate": false
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://Norge360-auth-api:8080/"
          }
        }
      },
      "accounts-api-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:00:15",
          "Version": "2",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 256,
          "EnableMultipleHttp2Connections": true,
          "DangerousAcceptAnyServerCertificate": false
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://Norge360-accounts-api:8080/"
          }
        }
      },
      "search-api-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:00:15",
          "Version": "2",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 256,
          "EnableMultipleHttp2Connections": true,
          "DangerousAcceptAnyServerCertificate": false
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://Norge360-search-api:8080/"
          }
        }
      }
    }
  }
}
