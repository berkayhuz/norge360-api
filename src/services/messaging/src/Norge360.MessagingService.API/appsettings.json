{
  "Messaging": {
    "Rules": {
      "EditWindowSeconds": 600,
      "RecallWindowSeconds": 600,
      "MaxPageSize": 100,
      "MaxGroupParticipants": 250,
      "MaxBulkRecipients": 50,
      "MaxMessageCipherTextBytes": 65536,
      "MaxAttachmentCount": 10
    },
    "RabbitMq": {
      "Uri": "amqp://guest:guest@localhost:5672/",
      "Exchange": "Norge360.integration"
    }
  },
  "Security": {
    "TokenTransport": {
      "AccessCookieName": "Norge360-access"
    },
    "TrustedGateway": {
      "RequireTrustedGateway": false,
      "CurrentKeyId": "",
      "AllowedSources": [],
      "Keys": []
    }
  },
  "Authentication": {
    "JwtBearer": {
      "RequireHttpsMetadata": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
