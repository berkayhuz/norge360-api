{
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Information",
                                     "Microsoft.AspNetCore":  "Warning"
                                 }
                },
    "Search":  {
                   "Provider":  "Meilisearch",
                   "IndexName":  "searchdocuments",
                   "StaticIndexing":  {
                                          "Enabled":  false,
                                          "SeedOnStartup":  false,
                                          "StartupSeedMaxAttempts":  5,
                                          "StartupSeedRetryDelaySeconds":  2
                                      },
                   "BlockFilter":  {
                                       "Enabled":  true,
                                       "AccountsApiBaseUrl":  "http://localhost:5005"
                                   }
               },
    "Authentication":  {
                           "Jwt":  {
                                       "Issuer":  "https://localhost:7223",
                                       "Audience":  "https://localhost:7025",
                                       "Authority":  "https://localhost:7223",
                                       "MetadataAddress":  "https://localhost:7223/.well-known/openid-configuration"
                                   }
                       },
    "Meilisearch":  {
                        "Endpoint":  "http://localhost:7700",
                        "ApiKey":  "<set-in-environment>"
                    }
}
