{
    "Search":  {
                   "Provider":  "Meilisearch",
                   "IndexName":  "searchdocuments",
                   "StaticIndexing":  {
                                          "Enabled":  true,
                                          "SeedOnStartup":  true,
                                          "StartupSeedMaxAttempts":  10,
                                          "StartupSeedRetryDelaySeconds":  2
                                      },
                   "BlockFilter":  {
                                       "Enabled":  true,
                                       "AccountsApiBaseUrl":  "http://localhost:5005"
                                   }
               },
    "Authentication":  {
                           "Jwt":  {
                                       "Issuer":  "http://localhost:5297",
                                       "Audience":  "http://localhost:5030",
                                       "Authority":  "http://localhost:5297",
                                       "MetadataAddress":  "http://localhost:5297/.well-known/openid-configuration"
                                   }
                       },
    "Meilisearch":  {
                        "Endpoint":  "http://localhost:7700",
                        "ApiKey":  "<set-in-environment>"
                    }
}
