{
  "Search": {
    "Provider": "Meilisearch",
    "IndexName": "searchdocuments",
    "StaticIndexing": {
      "Enabled": false,
      "SeedOnStartup": false,
      "StartupSeedMaxAttempts": 5,
      "StartupSeedRetryDelaySeconds": 2
    },
    "IntegrationConsumer": {
      "Enabled": true,
      "QueueName": "norge360.search.indexer",
      "RoutingKeyPatterns": ["search.document.index.requested.v1", "search.document.delete.requested.v1", "search.reindex.requested.v1"],
      "ProcessingFailureRequeueDelaySeconds": 0
    }
  },
  "Meilisearch": {
    "Endpoint": "http://localhost:7700",
    "ApiKey": "<set-in-environment>"
  },
  "Messaging": {
    "RabbitMq": {
      "Uri": "amqp://guest:guest@localhost:5672/",
      "Exchange": "norge360.search",
      "NetworkRecoveryIntervalSeconds": 10,
      "ConsumerDispatchConcurrency": 4,
      "PrefetchCount": 16
    }
  }
}
