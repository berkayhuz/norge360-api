{
  "Authentication": {
    "JwtBearer": {
      "Authority": "https://localhost:7223",
      "MetadataAddress": "https://localhost:7025/.well-known/openid-configuration",
      "Issuer": "https://localhost:7223",
      "Audience": "api://norge360",
      "RequireHttpsMetadata": true
    }
  },
  "Security": {
    "TrustedGateway": {
      "RequireTrustedGateway": true,
      "Source": "gateway",
      "CurrentKeyId": "local-dev-key",
      "AllowedSources": [
        "gateway"
      ],
      "AllowedClockSkewSeconds": 30,
      "ReplayProtectionWindowSeconds": 120,
      "AllowedGatewayProxies": [
        "::1",
        "127.0.0.1"
      ],
      "AllowedGatewayNetworks": [],
      "SignatureHeaderName": "X-Gateway-Signature",
      "TimestampHeaderName": "X-Gateway-Timestamp",
      "KeyIdHeaderName": "X-Gateway-Key-Id",
      "SourceHeaderName": "X-Gateway-Source",
      "NonceHeaderName": "X-Gateway-Request-Id",
      "ContentHashHeaderName": "X-Gateway-Content-SHA256",
      "Keys": [
        {
          "KeyId": "local-dev-key",
          "Secret": "REPLACE_WITH_AT_LEAST_32_CHAR_LOCAL_DEV_SECRET",
          "Enabled": true
        }
      ]
    }
  },
  "Services": {
    "Accounts": {
      "BaseUrl": "http://localhost:5030"
    },
    "Discovery": {
      "Enabled": false,
      "BaseUrl": "http://localhost:5302",
      "InternalTokenHeaderName": "X-Discovery-Internal-Token",
      "InternalToken": ""
    }
  },
  "Messaging": {
    "RabbitMq": {
      "Uri": "amqp://guest:guest@localhost:5672/",
      "Exchange": "Norge360.integration"
    }
  },
  "Media": {
    "PublicBaseUrl": "https://cdn.norge360.com",
    "StorageProvider": "CloudflareR2"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "InternalServices": {
    "Signing": {
      "Enabled": false,
      "Secret": "",
      "ClockSkewSeconds": 120,
      "ServiceName": "community-api"
    }
  }
}
