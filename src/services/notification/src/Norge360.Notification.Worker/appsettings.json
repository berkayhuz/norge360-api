{
  "ConnectionStrings": {
    "NotificationConnection": ""
  },
  "Notification": {
    "Database": {
      "ApplyMigrationsOnStartup": false
    },
    "Dispatch": {
      "MaxAttempts": 3,
      "RetryDelayMilliseconds": 250,
      "MaxRetryDelaySeconds": 30
    },
    "Worker": {
      "MaxConcurrentMessages": 4,
      "EmptyQueueDelayMilliseconds": 500,
      "DeadLetterUnexpectedFailures": true
    },
    "RabbitMq": {
      "Host": "localhost",
      "Port": 5672,
      "Username": "__SET_BY_ENV__",
      "QueueName": "Norge360.notification.dispatch.v1",
      "DeadLetterExchangeName": "Norge360.notification.dlx",
      "DeadLetterQueueName": "Norge360.notification.dispatch.dlq.v1",
      "DeadLetterRoutingKey": "notification.dispatch.dead",
      "UseQuorumQueue": true,
      "NetworkRecoveryIntervalSeconds": 10,
      "PrefetchCount": 8
    },
    "IntegrationConsumer": {
      "Enabled": true,
      "QueueName": "Norge360.notification.integration.v1"
    },
    "Email": {
      "Provider": "smtp",
      "ApprovedSenderDomains": ["norge360.com"],
      "Smtp": {
        "Host": "",
        "Port": 587,
        "FromAddress": "notifications@norge360.com",
        "FromName": "Norge360 Notifications",
        "UserName": "",
        "UseStartTls": true
      },
      "AmazonSes": {
        "Region": "eu-central-1",
        "FromAddress": "notifications@norge360.com",
        "FromName": "Norge360 Notifications",
        "AccessKeyId": "",
        "EndpointUrl": "",
        "ConfigurationSetName": ""
      }
    }
  },
  "Infrastructure": {
    "AwsParameterStore": {
      "Enabled": false,
      "RequireInProduction": true,
      "OptionalWhenEnabled": true,
      "Recursive": true,
      "DecryptSecureString": true,
      "ReloadOnChange": false,
      "ReloadAfterSeconds": 300,
      "ParameterPathPrefix": "/norge360/{environment}",
      "Region": "",
      "RequiredConfigurationKeys": [
        "ConnectionStrings:NotificationConnection"
      ]
    }
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Messaging": {
    "RabbitMq": {
      "Uri": "__SET_BY_ENV__",
      "Exchange": "Norge360.integration",
      "NetworkRecoveryIntervalSeconds": 10,
      "ConsumerDispatchConcurrency": 4,
      "PrefetchCount": 16
    }
  }
}
