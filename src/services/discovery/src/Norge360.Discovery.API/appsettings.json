{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DiscoveryConnection": "Host=DB_HOST;Port=5433;Database=norge360_discovery;Username=DB_USER;Password=DB_PASSWORD;Include Error Detail=true"
  },
  "Discovery": {
    "Database": {
      "MigrateOnStartup": true
    }
  },
  "Services": {
    "Accounts": {
      "BaseUrl": "http://localhost:5289",
      "InternalTokenHeaderName": "X-Discovery-Internal-Token",
      "InternalToken": ""
    }
  },
  "Authentication": {
    "JwtBearer": {
      "Authority": "https://auth.local",
      "MetadataAddress": "http://localhost:5297/.well-known/openid-configuration",
      "Issuer": "https://auth.local",
      "Audience": "api://norge360",
      "RequireHttpsMetadata": false
    }
  },
  "Security": {
    "TrustedGateway": {
      "RequireTrustedGateway": true,
      "Source": "Norge360.ApiGateway",
      "AllowedSources": ["Norge360.ApiGateway"],
      "CurrentKeyId": "gateway-local-key-2026-01",
      "AllowedGatewayProxies": ["127.0.0.1", "::1"],
      "AllowedGatewayNetworks": [],
      "Keys": [
        {
          "KeyId": "gateway-local-key-2026-01",
          "Secret": "",
          "Enabled": true,
          "SignRequests": true
        }
      ]
    },
    "InternalEvents": {
      "Enabled": true,
      "HeaderName": "X-Discovery-Internal-Token",
      "Token": ""
    }
  }
}
