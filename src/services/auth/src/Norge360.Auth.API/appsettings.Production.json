{
  "AllowedHosts": "auth.norge360.com;Norge360-auth-api",
  "ConnectionStrings": {
    "IdentityConnection": "Host=DB_HOST;Port=5433;Database=norge360_auth;Username=DB_USER;Password=DB_PASSWORD;Pooling=true;Maximum Pool Size=100;Timeout=15;Command Timeout=30"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080"
      },
      "Https": {
        "Url": "https://+:8443"
      }
    }
  },
  "OpenApi": {
    "Title": "Norge360 Auth API",
    "Version": "v1"
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Cloudflare": {
    "Turnstile": {
      "Enabled": true,
      "SecretKey": "",
      "AllowedHostnames": [
        "norge360.com",
        "auth.norge360.com"
      ]
    }
  },
  "Auth": {
    "Login": {
      "AccountsGatewayBaseUrl": "http://Norge360-ApiGateway:8080/"
    }
  },
  "Messaging": {
    "RabbitMq": {
      "Uri": "",
      "Exchange": "Norge360.integration",
      "NetworkRecoveryIntervalSeconds": 10,
      "ConsumerDispatchConcurrency": 4,
      "PrefetchCount": 16
    }
  },
  "Security": {
    "Cors": {
      "AllowedOrigins": [
        "https://norge360.com"
      ],
      "AllowCredentials": true
    },
    "ForwardedHeaders": {
      "ForwardLimit": 2,
      "KnownProxies": [],
      "KnownNetworks": [
        "10.0.0.0/8"
      ]
    },
    "Headers": {
      "ContentSecurityPolicy": "default-src 'none'; frame-ancestors 'none'; frame-src 'none'; base-uri 'none'; object-src 'none'; form-action 'none';",
      "ReferrerPolicy": "no-referrer",
      "PermissionsPolicy": "camera=(), geolocation=(), microphone=()",
      "EnableHsts": true,
      "HstsMaxAgeSeconds": 31536000,
      "PreloadHsts": true,
      "IncludeSubDomains": true
    },
    "TokenTransport": {
      "Mode": "CookiesOnly",
      "AllowRefreshTokenFromRequestBody": false,
      "AllowSessionIdFromRequestBody": false,
      "AccessCookieName": "Norge360-access",
      "RefreshCookieName": "Norge360-refresh",
      "SessionCookieName": "Norge360-session",
      "SameSite": "Lax",
      "AccessCookiePath": "/",
      "RefreshCookiePath": "/api/auth",
      "SessionCookiePath": "/api/auth",
      "CookieDomain": ".Norge360.com"
    },
    "TrustedGateway": {
      "RequireTrustedGateway": true,
      "Source": "Norge360.ApiGateway",
      "AllowedSources": [
        "Norge360.ApiGateway",
        "Norge360.Account"
      ],
      "CurrentKeyId": "gateway-prod-key-2026-01",
      "SignatureHeaderName": "X-Gateway-Signature",
      "TimestampHeaderName": "X-Gateway-Timestamp",
      "KeyIdHeaderName": "X-Gateway-Key-Id",
      "SourceHeaderName": "X-Gateway-Source",
      "NonceHeaderName": "X-Gateway-Request-Id",
      "ContentHashHeaderName": "X-Gateway-Content-SHA256",
      "AllowedClockSkewSeconds": 30,
      "ReplayProtectionWindowSeconds": 90,
      "AllowedGatewayProxies": [],
      "AllowedGatewayNetworks": [
        "10.0.0.0/8"
      ],
      "Keys": [
        {
          "KeyId": "gateway-prod-key-2026-01",
          "Secret": "",
          "Enabled": true,
          "SignRequests": true
        },
        {
          "KeyId": "account-internal-prod-key-2026-01",
          "Secret": "",
          "Enabled": true,
          "SignRequests": false
        }
      ]
    },
    "InternalIdentity": {
      "AllowedSources": [
        "Norge360.Account"
      ]
    },
    "RateLimiting": {
      "Global": {
        "PermitLimit": 120,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Login": {
        "PermitLimit": 5,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Register": {
        "PermitLimit": 3,
        "WindowSeconds": 300,
        "QueueLimit": 0
      },
      "Refresh": {
        "PermitLimit": 10,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Logout": {
        "PermitLimit": 20,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "RoleManagement": {
        "PermitLimit": 20,
        "WindowSeconds": 300,
        "QueueLimit": 0
      },
      "PasswordRecovery": {
        "PermitLimit": 3,
        "WindowSeconds": 300,
        "QueueLimit": 0
      },
      "EmailConfirmation": {
        "PermitLimit": 5,
        "WindowSeconds": 300,
        "QueueLimit": 0
      }
    },
    "Alerts": {
      "EnableStructuredAlerts": true
    },
    "TokenValidationCache": {
      "EnableCache": true,
      "AbsoluteExpirationSeconds": 15,
      "NegativeAbsoluteExpirationSeconds": 10,
      "KeyPrefix": "auth:user-token-state"
    }
  },
  "Jwt": {
    "Issuer": "https://auth.norge360.com",
    "Audience": "api://norge360",
    "AccessTokenMinutes": 15,
    "RefreshTokenHours": 8,
    "RefreshTokenPersistentDays": 14,
    "SigningKeys": [
      {
        "KeyId": "auth-rsa-prod-2026-01",
        "IsCurrent": true,
        "PrivateKeyPath": "/run/secrets/Norge360-auth-signing.pem",
        "PrivateKeyPem": ""
      }
    ]
  },
  "IdentitySecurity": {
    "MaxFailedAccessAttempts": 5,
    "LockoutMinutes": 15
  },
  "AccountLifecycle": {
    "RequireConfirmedEmailForLogin": true,
    "EmailConfirmationTokenMinutes": 1440,
    "PasswordResetTokenMinutes": 30,
    "PasswordResetCooldownSeconds": 60,
    "EmailChangeTokenMinutes": 30,
    "EmailConfirmationResendCooldownSeconds": 120,
    "TokenBytes": 32,
    "PublicAppBaseUrl": "https://auth.norge360.com",
    "ConfirmEmailPath": "/confirm-email",
    "ResetPasswordPath": "/reset-password",
    "ConfirmEmailChangePath": "/confirm-email-change"
  },
  "PasswordPolicy": {
    "MinimumLength": 12,
    "MaxLength": 128,
    "RequiredUniqueChars": 4,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireNonAlphanumeric": true,
    "DisallowWhitespace": true,
    "BlacklistedPasswords": [
      "Password123!",
      "Qwerty123!",
      "Admin123!",
      "12345678"
    ]
  },
  "Seed": {
    "AllowStartupSeed": false,
    "AllowProductionStartupSeed": false
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Authorization": {
    "DefaultPermissions": [
      "session:self",
      "profile:self"
    ],
    "Policies": [
      {
        "Name": "session:self",
        "RequiredPermissions": [
          "session:self"
        ],
        "RequiredRoles": [],
        "RequireAuthenticatedUser": true
      },
      {
        "Name": "users.invite",
        "RequiredPermissions": [
          "users.invite"
        ],
        "RequiredRoles": [],
        "RequireAuthenticatedUser": true
      },
      {
        "Name": "roles.read",
        "RequiredPermissions": [
          "roles.read"
        ],
        "RequiredRoles": [],
        "RequireAuthenticatedUser": true
      },
      {
        "Name": "roles.manage",
        "RequiredPermissions": [
          "roles.manage"
        ],
        "RequiredRoles": [],
        "RequireAuthenticatedUser": true
      }
    ]
  },
  "SessionSecurity": {
    "MaxActiveSessions": 5,
    "IdleTimeoutMinutes": 1440,
    "AbsoluteLifetimeDays": 14
  },
  "DataRetention": {
    "EnableCleanupService": true,
    "CleanupIntervalMinutes": 60,
    "AuditRetentionDays": 90,
    "RevokedSessionRetentionDays": 30
  },
  "Infrastructure": {
    "AwsParameterStore": {
      "Enabled": true,
      "RequireInProduction": true,
      "OptionalWhenEnabled": false,
      "Recursive": true,
      "DecryptSecureString": true,
      "ReloadOnChange": false,
      "ReloadAfterSeconds": 300,
      "ParameterPathPrefix": "/norge360/{environment}",
      "Region": "eu-central-1",
      "RequiredConfigurationKeys": [
        "ConnectionStrings:IdentityConnection",
        "Messaging:RabbitMq:Uri",
        "Infrastructure:DistributedCache:RedisConnectionString"
      ]
    },
    "DistributedCache": {
      "Provider": "Redis",
      "RedisConnectionString": "",
      "InstanceName": "Norge360:Auth:",
      "ConnectTimeoutMilliseconds": 5000,
      "AsyncTimeoutMilliseconds": 5000,
      "SyncTimeoutMilliseconds": 5000,
      "ConnectRetry": 3,
      "AbortOnConnectFail": false,
      "RequireExternalProviderInProduction": true
    },
    "DataProtection": {
      "ApplicationName": "Norge360.Auth",
      "KeyRingPath": null,
      "RedisConnectionString": "",
      "RequirePersistentKeyRingInProduction": true
    }
  }
}


